# OPENAI_API_KEY should hold the iFlytek APIPassword single token from the console; it may contain a colon, so paste it verbatim.
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=lite
OPENAI_BASE_URL=https://spark-api-open.xf-yun.com/v1

# iFlytek Spark credentials
# SPARK_APP_ID and SPARK_API_SECRET are not used by the OpenAI-compat HTTP path; they are reserved for an optional WebSocket integration.
SPARK_APP_ID=your_app_id_here
SPARK_API_SECRET=your_api_secret_here

MONGO_URI=mongodb://localhost:27017
MONGO_DB=cs_buddy
